# Qdrant Vector Database (required)
# Get your credentials from https://cloud.qdrant.io/
QDRANT_URL=your-qdrant-url
QDRANT_API_KEY=your-qdrant-api-key

# Groq API Key (for LLM) — at least one of Groq or OpenAI required
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key

# OpenAI API Key (optional, alternative to Groq)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Agent Layer Configuration (optional)
# LLM provider: "groq" (default) or "openai"
ARTEMIS_LLM_PROVIDER=groq

# Model name (provider-specific)
# Groq default: "llama-3.3-70b-versatile"
# OpenAI default: "gpt-4o-mini"
ARTEMIS_LLM_MODEL=llama-3.3-70b-versatile

# Generation parameters
ARTEMIS_MAX_TOKENS=2048
ARTEMIS_TEMPERATURE=0.7

# Retrieval parameters
ARTEMIS_RETRIEVAL_K=5

# Optional — only for Kaggle dataset downloads (e.g. dataset/). Not required for the agent or API.
# Get your credentials from https://www.kaggle.com/account
# KAGGLE_USERNAME=your-kaggle-username
# KAGGLE_KEY=your-kaggle-api-key

# Optional: Custom dataset cache location
# KAGGLEHUB_CACHE=/path/to/cache

# Logging Configuration
# Set log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
ARTEMIS_LOG_LEVEL=INFO

# Document Storage Configuration
# Set to "true" to save documents to files (useful for testing/large datasets)
# Default: false (in-memory mode, faster for small datasets)
ARTEMIS_SAVE_DOCS_TO_DISK=true
