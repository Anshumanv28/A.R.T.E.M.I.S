# Kaggle API Credentials
# Get your credentials from https://www.kaggle.com/account
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Qdrant Vector Database
# Get your credentials from https://cloud.qdrant.io/
QDRANT_URL=your-qdrant-url
QDRANT_API_KEY=your-qdrant-api-key

# Groq API Key (for LLM)
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key

# Optional: Custom dataset cache location
# KAGGLEHUB_CACHE=/path/to/cache

# Logging Configuration
# Set log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
ARTEMIS_LOG_LEVEL=INFO

# Document Storage Configuration
# Set to "true" to save documents to files (useful for testing/large datasets)
# Default: false (in-memory mode, faster for small datasets)
ARTEMIS_SAVE_DOCS_TO_DISK=true
